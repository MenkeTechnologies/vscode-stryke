{
  "name": "vscode-stryke",
  "displayName": "stryke",
  "description": "Language support for stryke — syntax highlighting (the complete builtin surface), filetype detection, LSP (stryke --lsp), running, and full debugging (breakpoints, stepping, variables) via stryke --dap.",
  "version": "0.2.0",
  "publisher": "MenkeTechnologies",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "stryke",
    "perl",
    "stk",
    "parallel",
    "lsp",
    "debug"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MenkeTechnologies/vscode-stryke.git"
  },
  "homepage": "https://menketechnologies.github.io/vscode-stryke/",
  "bugs": {
    "url": "https://github.com/MenkeTechnologies/vscode-stryke/issues"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:stryke",
    "onDebugResolve:stryke",
    "onDebugDynamicConfigurations:stryke"
  ],
  "contributes": {
    "languages": [
      {
        "id": "stryke",
        "aliases": [
          "Stryke",
          "stryke"
        ],
        "extensions": [
          ".stk"
        ],
        "filenames": [],
        "firstLine": "^#!.*\\bstryke\\b",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "stryke",
        "scopeName": "source.stryke",
        "path": "./syntaxes/stryke.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "stryke",
      "properties": {
        "stryke.path": {
          "type": "string",
          "default": "stryke",
          "description": "Path to the stryke executable used for the language server, running, and debugging."
        },
        "stryke.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Start the stryke language server (stryke --lsp). Disable to use syntax highlighting only."
        },
        "stryke.lsp.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--lsp"
          ],
          "description": "Arguments passed to the stryke executable to start the language server."
        }
      }
    },
    "commands": [
      {
        "command": "stryke.run",
        "title": "Run File",
        "category": "Stryke",
        "icon": "$(play)"
      },
      {
        "command": "stryke.debug",
        "title": "Debug File",
        "category": "Stryke",
        "icon": "$(debug-alt)"
      }
    ],
    "keybindings": [
      {
        "command": "stryke.run",
        "key": "ctrl+f5",
        "mac": "ctrl+f5",
        "when": "editorLangId == stryke"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "stryke.run",
          "when": "resourceLangId == stryke",
          "group": "navigation@1"
        },
        {
          "command": "stryke.debug",
          "when": "resourceLangId == stryke",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "stryke.run",
          "when": "editorLangId == stryke"
        },
        {
          "command": "stryke.debug",
          "when": "editorLangId == stryke"
        }
      ]
    },
    "breakpoints": [
      {
        "language": "stryke"
      }
    ],
    "debuggers": [
      {
        "type": "stryke",
        "label": "Stryke",
        "languages": [
          "stryke"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the .stk script to debug.",
                "default": "${file}"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command-line arguments passed to the script.",
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debugged program.",
                "default": "${workspaceFolder}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Break on the first line of the program.",
                "default": false
              },
              "noDebug": {
                "type": "boolean",
                "description": "Run without the debugger (ignore breakpoints).",
                "default": false
              },
              "interpreterArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Extra arguments passed to the stryke interpreter itself.",
                "default": []
              },
              "strykePath": {
                "type": "string",
                "description": "Override the stryke executable for this debug session. Defaults to the resolved \"stryke.path\"."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "stryke",
            "request": "launch",
            "name": "Stryke: Debug Current File",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "Stryke: Debug Current File",
            "description": "Debug the active .stk file with stryke --dap",
            "body": {
              "type": "stryke",
              "request": "launch",
              "name": "Stryke: Debug Current File",
              "program": "^\"\\${file}\"",
              "cwd": "^\"\\${workspaceFolder}\"",
              "stopOnEntry": false
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "gen": "bash scripts/gen_grammar.sh",
    "vscode:prepublish": "echo no build step"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.1.0"
  }
}
